APP_BIND=127.0.0.1
APP_PORT=8000
BURN_RATE_IMAGE=loomitz/burnrate:v0.1.9

DB_NAME=burn_rate
DB_USER=burn_rate
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432

DJANGO_SECRET_KEY=change-me-to-a-long-random-value
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_TRUST_X_FORWARDED_PROTO=false
DJANGO_SESSION_COOKIE_AGE=2592000
DJANGO_SESSION_SAVE_EVERY_REQUEST=true
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax

INVITATION_TTL_DAYS=14
BURN_RATE_PUBLIC_URL=http://localhost:8000
BURN_RATE_FRONTEND_URL=http://localhost:8000
BURN_RATE_INVITATION_ACCEPT_URL=

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=

RUN_MIGRATIONS=true
COLLECT_STATIC=true
WAIT_FOR_DB=true
DB_WAIT_TIMEOUT=30
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60
